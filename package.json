{
  "name": "hono-example",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently --names \"api,ui\" \"npm run api\" \"vite\"",
    "api": "node --insecure-http-parser --env-file=.env node_modules/.bin/tsx --watch server.ts",
    "build": "vite build",
    "test": "vitest run",
    "test:esv": "vitest run tests/esv.test.ts"
  },
  "dependencies": {
    "@enterprisestandard/react": "^0.0.12",
    "@enterprisestandard/server": "^0.0.12",
    "@enterprisestandard/valibot": "^0.0.12",
    "@hono/node-server": "^1.19.11",
    "hono": "^4.9.8",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tailwindcss": "^4.1.14",
    "tw-animate-css": "^1.4.0",
    "valibot": "^1.2.0"
  },
  "devDependencies": {
    "@enterprisestandard/esv": "0.0.5-beta.20260114.1",
    "@tailwindcss/vite": "^4.1.14",
    "@types/node": "^22.0.0",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.3",
    "concurrently": "^9.2.1",
    "globals": "^16.4.0",
    "tsx": "^4.0.0",
    "typescript": "^5.9.3",
    "vite": "^7.1.7",
    "vitest": "^3.0.0"
  }
}
